name: ledra-rollback

on:
  workflow_dispatch:
    inputs:
      deploy_ref:
        description: Repository ref or commit SHA to redeploy
        required: true
      target_environment:
        description: Deployment target
        required: true
        type: choice
        options:
          - production

permissions:
  contents: read
env:
  LEDRA_REGISTRY_PATH: registry

jobs:
  build-rollback:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repository at target ref
        uses: actions/checkout@v4
        with:
          ref: ${{ inputs.deploy_ref }}

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: 20

      - name: Install dependencies
        run: npm install

      - name: Build repository
        run: npm run build

      - name: Run tests
        run: npm test

      - name: Validate rollback registry data
        run: npm exec --workspace @ledra/cli ledra -- validate --registry "${{ github.workspace }}/${{ env.LEDRA_REGISTRY_PATH }}"

      - name: Export rollback bundle
        run: npm exec --workspace @ledra/cli ledra -- export --registry "${{ github.workspace }}/${{ env.LEDRA_REGISTRY_PATH }}" --out ".artifacts/cloudflare/bundle.json"

      - name: Resolve rollback commit SHA
        id: rollback-sha
        run: printf 'sha=%s\n' "$(git rev-parse HEAD)" >> "$GITHUB_OUTPUT"

      - name: Package Cloudflare assets
        run: >-
          node scripts/package-cloudflare.mjs
          --bundle .artifacts/cloudflare/bundle.json
          --out deploy/cloudflare/public
          --repo "${{ github.repository }}"
          --ref "${{ inputs.deploy_ref }}"
          --commit "${{ steps.rollback-sha.outputs.sha }}"
          --registry-path "${{ env.LEDRA_REGISTRY_PATH }}"

      - name: Upload packaged assets
        uses: actions/upload-artifact@v4
        with:
          name: ledra-rollback-package
          path: deploy/cloudflare/public

  deploy-rollback:
    needs: build-rollback
    runs-on: ubuntu-latest
    environment: ${{ inputs.target_environment }}
    steps:
      - name: Checkout trusted repository config
        uses: actions/checkout@v4
        with:
          ref: refs/heads/${{ github.event.repository.default_branch }}

      - name: Download packaged assets
        uses: actions/download-artifact@v4
        with:
          name: ledra-rollback-package
          path: deploy/cloudflare/public

      - name: Copy Wrangler config
        run: cp deploy/cloudflare/wrangler.toml.example deploy/cloudflare/wrangler.toml

      - name: Deploy rollback build
        uses: cloudflare/wrangler-action@v3
        with:
          apiToken: ${{ secrets.CLOUDFLARE_API_TOKEN }}
          accountId: ${{ secrets.CLOUDFLARE_ACCOUNT_ID }}
          workingDirectory: deploy/cloudflare
          command: deploy --env ${{ inputs.target_environment }}

      - name: Verify rollback deployment
        if: ${{ inputs.target_environment == 'production' }}
        run: |
          curl --fail --silent --show-error "https://${{ vars.CLOUDFLARE_PRODUCTION_HOSTNAME }}/health"
          curl --fail --silent --show-error "https://${{ vars.CLOUDFLARE_PRODUCTION_HOSTNAME }}/bundle.json" >/dev/null
          curl --fail --silent --show-error "https://${{ vars.CLOUDFLARE_PRODUCTION_HOSTNAME }}/api/views" >/dev/null
          curl --fail --silent --show-error "https://${{ vars.CLOUDFLARE_PRODUCTION_HOSTNAME }}/api/metadata" >/dev/null
